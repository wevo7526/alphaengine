# AlphaEngine gateway (mcp-server) environment.

# Auth. Local/dev: AUTH_STUB=1 bypasses auth. PRODUCTION MUST set AUTH_STUB=0.
AUTH_STUB=1
# Per-client paid keys, comma-separated "key:client_id".
MCP_API_KEYS=
# Public, rate-limited sandbox key (eval). Override the default in production.
SANDBOX_API_KEY=ae_sandbox_public
# Quotas.
SANDBOX_RATE_LIMIT=60
SANDBOX_WINDOW_S=60
PAID_DAILY_QUOTA=100000

# Server.
PORT=8080

# Agent-job plane (T7) only — not needed for the deterministic + MCP planes.
# ANTHROPIC_API_KEY=
